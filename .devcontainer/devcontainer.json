{
  "$schema": "./devcontainer.schema.json",
  "name": "PulseControl Cloud Dev",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspaces/PulseControl",
  "shutdownAction": "stopCompose",
  "runServices": ["db"],
  "forwardPorts": [3001, 3002, 5432],
  "portsAttributes": {
    "3001": { "label": "Frontend", "onAutoForward": "openBrowser" },
    "3002": { "label": "Backend API", "onAutoForward": "notify" },
    "5432": { "label": "PostgreSQL", "onAutoForward": "silent" }
  },
  "remoteEnv": {
    "DB_HOST": "db",
    "DB_PORT": "5432",
    "DB_USER": "postgres",
    "DB_PASSWORD": "password123",
    "DB_NAME": "pulse_erp_db",
    "JWT_SECRET": "devcontainer-jwt-secret-change-for-production",
    "APP_PORT": "3002",
    "NODE_ENV": "development",
    "CORS_ORIGIN": "http://localhost:3001,http://127.0.0.1:3001"
  },
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "ms-azuretools.vscode-docker"
      ]
    }
  }
}
