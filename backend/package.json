{
  "name": "backend",
  "version": "1.0.0",
  "description": "PulseControlERP Backend API",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "node -r dotenv/config dist/main.js",
    "start:dev": "ts-node -r dotenv/config src/main.ts",
    "start:dev:3012": "set APP_PORT=3012&& ts-node -r dotenv/config src/main.ts",
    "start:test": "set NODE_ENV=test&& ts-node -r dotenv/config src/main.ts",
    "start:debug": "ts-node -r dotenv/config --inspect src/main.ts",
    "db:check": "ts-node -r dotenv/config src/scripts/check-db.ts",
    "db:check:test": "set NODE_ENV=test&& ts-node -r dotenv/config src/scripts/check-db.ts",
    "smoke:permissions": "powershell -ExecutionPolicy Bypass -File scripts/smoke-permissions.ps1",
    "smoke:permissions:isolated": "powershell -ExecutionPolicy Bypass -File scripts/smoke-permissions-isolated.ps1",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@nestjs/common": "^11.1.16",
    "@nestjs/core": "^11.1.16",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.16",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/typeorm": "^11.0.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "dotenv": "^16.6.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^25.3.5",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.18.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
